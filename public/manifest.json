{
  "manifest_version": 3,
  "name": "Skip Wait - Bypass Timers & Countdowns",
  "version": "1.4.33",
  "description": "Bypass countdown timers and skip waiting pages. Instant access on link shorteners and file hosts - no wait, one click.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_popup": "popup.html"
  },
  "permissions": ["scripting", "storage", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
